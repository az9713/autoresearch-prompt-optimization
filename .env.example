# Pick ONE provider. Gemini recommended (free tier available).
PROVIDER=gemini          # gemini | openrouter | anthropic

GOOGLE_API_KEY=          # for Gemini
OPENROUTER_API_KEY=      # for OpenRouter
ANTHROPIC_API_KEY=       # for Anthropic

# Optional: override default model for chosen provider
# MODEL=gemini-2.0-flash

# Cost controls (0 = unlimited / disabled)
MAX_ITERATIONS=100       # stop after N experiments
MAX_COST_USD=5.00        # stop if estimated cost exceeds this
PLATEAU_WINDOW=10        # stop if no improvement in last N iterations
